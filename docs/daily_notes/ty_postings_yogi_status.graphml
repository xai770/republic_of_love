  <graph edgedefault="directed" id="G">
    <data key="d0" xml:space="preserve">
      State machine for yogi_posting_events.event_type.
      Each node corresponds to a row written to yogi_posting_events.
      "dismissed"  = quick instinctive skip (minimal rationale expected).
      "not_applied" = deliberate decision after research (rationale required for Bewerbungsprotokoll).
      Both "dismissed" and "not_applied" fold into the old "no-go" state.
      "viewed"     absorbs the old "interested" state (clicking for details).
      "saved"      absorbs the old "favorites" state.
      "outcome_received" is new — employer reply to a submitted application.
    </data>

    <!-- ── start ─────────────────────────────────────────────────────── -->
    <node id="n0">
      <data key="d6">
        <y:GenericNode configuration="com.yworks.flowchart.terminator">
          <y:Geometry height="40.0" width="100.0" x="300.0" y="0.0"/>
          <y:Fill color="#E8EEF7" color2="#B7C9E3" transparent="false"/>
          <y:BorderStyle color="#000000" type="line" width="1.0"/>
          <y:NodeLabel alignment="center" autoSizePolicy="content" fontFamily="Dialog" fontSize="12" fontStyle="plain" hasBackgroundColor="false" hasLineColor="false" modelName="custom" textColor="#000000" visible="true" xml:space="preserve">start<y:LabelModel><y:SmartNodeLabelModel distance="4.0"/></y:LabelModel><y:ModelParameter><y:SmartNodeLabelModelParameter labelRatioX="0.0" labelRatioY="0.0" nodeRatioX="0.0" nodeRatioY="0.0" offsetX="0.0" offsetY="0.0" upX="0.0" upY="-1.0"/></y:ModelParameter></y:NodeLabel>
        </y:GenericNode>
      </data>
    </node>

